---
const { class: className, href, ...rest } = Astro.props
const isMailto = typeof href === "string" && href.startsWith("mailto:")
const baseClass =
  "inline-flex items-center justify-center gap-1.5 px-3 py-2 text-xs text-gray-800 transition bg-gray-100 border border-gray-300 rounded-full dark:bg-gray-800 dark:border-gray-600 dark:text-white focus-visible:ring-yellow-500/80 sm:gap-2 sm:px-4 sm:py-1 sm:text-sm hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-100 dark:hover:border-gray-300 dark:hover:text-black group max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:bg-black [touch-action:manipulation]"
---
<a
  {...rest}
  href={href}
  target={isMailto ? undefined : "_blank"}
  rel={isMailto ? "noopener" : "noopener noreferrer"}
  role="link"
  class:list={[baseClass, className]}
>
  <slot />
</a>
